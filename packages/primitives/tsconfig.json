{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",
    "tsBuildInfoFile": "./dist/tsconfig.tsbuildinfo",
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "noEmit": false
  },
  "include": [
    "./elements/**/*.ts",
    "./nodes/**/*.ts"
  ],
  "exclude": [
    "./dist",
    "./**/__tests__/**",
    "./**/*.spec.ts",
    "./**/*.spec.tsx",
    "./**/node_modules/**"
  ]
}
