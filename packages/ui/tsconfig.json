{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",
    "tsBuildInfoFile": "./dist/tsconfig.tsbuildinfo",
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "noEmit": false
  },
  "include": [
    "./components-base/**/*.ts",
    "./edgeless-dragging-area/**/*.ts",
    "./edgeless-selected-rect/**/*.ts",
    "./edgeless-toolbar/**/*.ts",
    "./edgeless-zoom-toolbar/**/*.ts",
    "./frame-title/**/*.ts",
    "./scroll-anchoring/**/*.ts",
    "./viewport-overlay/**/*.ts"
  ],
  "exclude": [
    "./dist",
    "./**/__tests__/**",
    "./**/*.spec.ts",
    "./**/*.spec.tsx",
    "./**/node_modules/**"
  ]
}
