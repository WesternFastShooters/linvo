{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": false,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "resolveJsonModule": true,
    "strict": true,
    "verbatimModuleSyntax": true,
    "jsx": "react-jsx",
    "allowJs": false,
    "noEmit": true,
    "isolatedModules": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": [
      "vite/client"
    ],
    "paths": {
      "@theme": [
        "./resources/theme/dist/index.d.ts"
      ],
      "@theme/style.css": [
        "./resources/theme/dist/style.css"
      ],
      "@theme/fonts.css": [
        "./resources/theme/fonts/fonts.css"
      ],
      "@theme/v2": [
        "./resources/theme/dist/v2/index.d.ts"
      ],
      "@icons/lit": [
        "./resources/icons/dist/lit.d.ts"
      ],
      "@icons/rc": [
        "./resources/icons/dist/rc.d.ts"
      ]
    }
  },
  "include": [
    "src",
    "packages"
  ]
}
