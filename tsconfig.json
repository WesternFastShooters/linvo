{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": false,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "strict": true,
    "verbatimModuleSyntax": true,
    "jsx": "react-jsx",
    "allowJs": false,
    "noEmit": true,
    "isolatedModules": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": [
      "vite/client"
    ]
  },
  "include": [
    "src",
    "packages"
  ]
}
